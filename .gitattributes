# Normalize text files in the repository and store them as LF.
* text=auto eol=lf

# Windows-native scripts retain CRLF where required.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files must never be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
