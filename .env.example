# MesaFlow local development settings.
# Do not commit real secrets or provider credentials.

APP_ENV=local
APP_URL=http://localhost:3000

# Local PostgreSQL for ENG-A0-002.
# These are safe development defaults only; do not reuse them for production.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=mesaflow
POSTGRES_PASSWORD=mesaflow_local_password
POSTGRES_DB=mesaflow
MESAFLOW_TEST_DATABASE=mesaflow_test
DATABASE_URL=postgres://mesaflow:mesaflow_local_password@127.0.0.1:5432/mesaflow
TEST_DATABASE_URL=postgres://mesaflow:mesaflow_local_password@127.0.0.1:5432/mesaflow_test
POSTGRES_ADMIN_URL=postgres://mesaflow:mesaflow_local_password@127.0.0.1:5432/postgres

# Technical-only ENG-A0-004 RLS probe role.
RLS_PROBE_DATABASE_URL=postgres://mesaflow_rls_probe_app:mesaflow_rls_probe_password@127.0.0.1:5432/mesaflow_test
